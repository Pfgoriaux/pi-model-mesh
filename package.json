{
  "name": "pi-model-mesh",
  "version": "0.2.0",
  "description": "Multi-model orchestration extension for pi (@claude, @codex, @glm, @all, @review, @deliberate, @judge)",
  "license": "MIT",
  "type": "module",
  "author": "PF Goriaux",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pfgoriaux/pi-model-mesh.git"
  },
  "bugs": {
    "url": "https://github.com/Pfgoriaux/pi-model-mesh/issues"
  },
  "homepage": "https://github.com/Pfgoriaux/pi-model-mesh#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "multi-model",
    "synthetic",
    "codex",
    "claude"
